{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .section--full-width {
    width: 100vw;
    margin-left: 0;
    margin-right: 0;
    box-sizing: border-box;
  }

  .section--full-width .rte {
    max-width: 1200px;
    margin: 0 auto;
  }

  .text-left { text-align: left; }
  .text-center { text-align: center; }
  .text-right { text-align: right; }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding
            {% if section.settings.full_width %}section--full-width{% else %}page-width{% endif %}
            {% if section.settings.text_align %}text-{{ section.settings.text_align }}{% endif %}">

  <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {{ page.content }}
  </div>
</div>

{{ 'nbhas-assessment.css' | asset_url | stylesheet_tag }}

{{ 'nbhas-dashboard.css' | asset_url | stylesheet_tag }}

<div id="nbhas-app"></div>

<script>
  window.NBHAS_MASTER_JSON_URL = "{{ 'nbhas-master-data.json' | asset_url }}";
  console.log("NBHAS JSON URL:", window.NBHAS_MASTER_JSON_URL);
</script>

<script src="{{ 'nbhas-engine.js' | asset_url }}" defer></script>
<script src="{{ 'nbhas-renderer.js' | asset_url }}" defer></script>
<script src="{{ 'nbhas-report.js' | asset_url }}" defer></script>
<script src="{{ 'nbhas-report-renderer.js' | asset_url }}" defer></script>
<script src="{{ 'nbhas-assessment.js' | asset_url }}" defer></script>


{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section full width",
      "default": false
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    }
  ]
}

{% endschema %}